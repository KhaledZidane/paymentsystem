      "item": [
        {
          "name": "Checkout Empty Cart → 422",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Create a fresh empty cart for this test",
                  "pm.sendRequest({",
                  "    url: pm.collectionVariables.get('baseUrl') + '/carts',",
                  "    method: 'POST'",
                  "}, (err, res) => {",
                  "    pm.collectionVariables.set('cartId', res.json().id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 422 for empty cart checkout', () => pm.response.to.have.status(422));",
                  "pm.test('Error message present', () => {",
                  "    pm.expect(pm.response.json().message).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/carts/{{cartId}}/checkout",
              "host": [
